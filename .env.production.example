APP_NAME="Quiniela"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Caracas
APP_URL=https://quiniela.dernait.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=quiniela
DB_USERNAME=quiniela
DB_PASSWORD=CAMBIA_ESTA_CLAVE
DB_ROOT_PASSWORD=CAMBIA_ESTA_CLAVE_ROOT

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Cuenta de administrador (anfitrión) que crea el seeder en producción.
ADMIN_NAME="Anfitrión"
ADMIN_EMAIL="admin@dernait.com"
ADMIN_PASSWORD="CAMBIA_ESTA_CLAVE_ADMIN"

# Optional API-Football integration. Leave blank to run fully manual.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# Puerto local donde escucha el nginx del contenedor (reverse proxy del host).
APP_PORT=8310

VITE_APP_NAME="${APP_NAME}"
